---
// 这里可以写 JavaScript/TypeScript，在构建时运行
const { title = '我的博客' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <!-- 引入我们自己写的样式 -->
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <!-- 导航栏 -->
  <nav class="navbar">
    <div class="nav-brand">Leexy Blog</div>
    <ul class="nav-links">
      <li><a href="/">首页</a></li>
      <li><a href="/blog">文章</a></li>
      <li><a href="/about">关于</a></li>
    </ul>
  </nav>

  <!-- 页面内容插槽 -->
  <main class="container">
    <slot />
  </main>

  <!-- 页脚 -->
  <footer class="footer">
    <p>© 2026 Leexy. Built with Astro.</p>
  </footer>
</body>
</html>